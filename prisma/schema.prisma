generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum PlanPriority {
  high
  medium
  low
}

enum PlanType {
  goal
  phase
  weekly
  daily
}

enum PlanStatus {
  not_started
  in_progress
  done
  archived
}

enum FeedItemType {
  plan
  memo
  contribution
}

enum FeedActionType {
  create
  update
  complete
  archive
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  avatar       String?
  role         UserRole @default(user)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  plans         Plan[]
  memos         Memo[]
  memoComments  MemoComment[]
  feeds         Feed[]
  contributions PlanContribution[]
  subscriptions Subscription[]

  @@map("users")
}

model Plan {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  title        String
  description  String?
  type         PlanType      @default(goal)
  parentPlanId String?       @map("parent_plan_id")
  startDate    DateTime?     @map("start_date")
  endDate      DateTime?     @map("end_date")
  status       PlanStatus    @default(not_started)
  color        String?       @default("#6366F1")
  priority     PlanPriority?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentPlan    Plan?              @relation("PlanHierarchy", fields: [parentPlanId], references: [id], onDelete: SetNull)
  subPlans      Plan[]             @relation("PlanHierarchy")
  linkedMemo    Memo?              @relation("PlanMemo")
  contributions PlanContribution[]

  @@index([userId])
  @@index([parentPlanId])
  @@index([type])
  @@map("plans")
}

model Memo {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  title        String
  description  String?
  body         String?  @db.Text
  linkedPlanId String?  @unique @map("linked_plan_id")
  posX         Float?   @map("pos_x")
  posY         Float?   @map("pos_y")
  zIndex       Int      @default(1) @map("z_index")
  color        String   @default("yellow")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedPlan Plan?         @relation("PlanMemo", fields: [linkedPlanId], references: [id], onDelete: Cascade)
  images     MemoImage[]
  comments   MemoComment[]

  @@index([userId])
  @@map("memos")
}

model MemoImage {
  id        String   @id @default(cuid())
  memoId    String   @map("memo_id")
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  memo Memo @relation(fields: [memoId], references: [id], onDelete: Cascade)

  @@index([memoId])
  @@map("memo_images")
}

model MemoComment {
  id        String   @id @default(cuid())
  memoId    String   @map("memo_id")
  userId    String   @map("user_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memo Memo @relation(fields: [memoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([memoId, createdAt])
  @@map("memo_comments")
}

model Feed {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  itemType   FeedItemType   @map("item_type")
  itemId     String         @map("item_id")
  actionType FeedActionType @map("action_type")
  content    String?
  createdAt  DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("feeds")
}

model PlanContribution {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  planId      String   @map("plan_id")
  title       String
  description String?
  body        String?  @db.Text
  occurredOn     DateTime  @map("occurred_on")
  occurredEndOn  DateTime? @map("occurred_end_on")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   Plan                 @relation(fields: [planId], references: [id], onDelete: Cascade)
  images ContributionImage[]

  @@index([userId, planId, occurredOn])
  @@index([userId, occurredOn])
  @@map("plan_contributions")
}

model ContributionImage {
  id             String   @id @default(cuid())
  contributionId String   @map("contribution_id")
  url            String
  createdAt      DateTime @default(now()) @map("created_at")

  contribution PlanContribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  @@index([contributionId])
  @@map("contribution_images")
}

model Subscription {
  id            String             @id @default(cuid())
  userId        String             @map("user_id")
  planName      String             @map("plan_name")
  status        SubscriptionStatus @default(active)
  startAt       DateTime           @map("start_at")
  endAt         DateTime           @map("end_at")
  paymentStatus PaymentStatus      @default(pending) @map("payment_status")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}
