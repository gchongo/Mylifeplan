# Database — 使用你创建的 meridian 用户，不要用 postgres
# 密码含 @ 等特殊字符时需 URL 编码，例如 @ → %40
DATABASE_URL="postgresql://meridian:your-password-url-encoded@localhost:5432/meridian?schema=public"

# Auth — 至少 32 位随机字符串（openssl rand -base64 32）
AUTH_SECRET="your-generated-secret-here"

# HTTP 访问（无 HTTPS）必须设为 false，否则登录 Cookie 无法保存
COOKIE_SECURE="false"

# 生产环境
NODE_ENV="production"
